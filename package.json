    "@typescript-eslint/parser": "^8.59.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.8.3",
    "reactotron-react-native": "^5.1.18",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
