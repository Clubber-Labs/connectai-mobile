# Em simulador iOS/Android, localhost funciona direto.
# Em device físico, prefira o hostname mDNS da máquina pra evitar trocar
# o IP a cada lease do DHCP: http://<SEU-HOSTNAME>.local:3333
# (rode `scutil --get LocalHostName` no Mac pra ver seu hostname)
API_URL=http://localhost:3333
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.ey...seu_token_aqui

# Remove o entitlement de push do build iOS local — necessário enquanto não
# houver Apple Developer Program pago (o profile do time gratuito não cobre
# aps-environment). SÓ pra dev local; nunca setar em build EAS/produção.
# Detalhes: RELEASE_CHECKLIST.md → "Push Notifications — iOS".
IOS_DISABLE_PUSH=1

# Push no Android (FCM): baixe o google-services.json do Firebase pra raiz do
# repo (gitignored) e aponte aqui. Sem ele o build funciona, mas push não chega.
# Detalhes: RELEASE_CHECKLIST.md → "Push (FCM)".
# GOOGLE_SERVICES_JSON=./google-services.json
